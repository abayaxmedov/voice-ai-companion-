# Local-first defaults. These keep the app runnable without paid/cloud accounts.
# For real ElevenLabs speech-to-speech, use:
# COMPANION_STT_PROVIDER=elevenlabs_stt
# COMPANION_LLM_PROVIDER=local_companion
# COMPANION_TTS_PROVIDER=elevenlabs
COMPANION_STT_PROVIDER=mock_stt
COMPANION_LLM_PROVIDER=mock_llm
COMPANION_TTS_PROVIDER=mock_tts
COMPANION_VOICE_ANALYSIS_PROVIDER=local_voice_analysis
COMPANION_AUDIO_CACHE_DIR=/private/tmp/voice-ai-companion/audio
COMPANION_ORCHESTRATOR_PUBLIC_BASE_URL=http://127.0.0.1:8765
# pipeline = STT/LLM/TTS path; hume_evi = browser mic -> local proxy -> Hume EVI.
COMPANION_VOICE_MODE=pipeline

# ElevenLabs STT/TTS. Required for ElevenLabs speech-to-speech pipeline.
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=
ELEVENLABS_STT_MODEL_ID=scribe_v2
ELEVENLABS_STT_LANGUAGE_CODE=uz
ELEVENLABS_MODEL_ID=eleven_flash_v2_5
ELEVENLABS_BASE_URL=https://api.elevenlabs.io
ELEVENLABS_OUTPUT_FORMAT=pcm_24000
# auto omits language_code for TTS; eleven_flash_v2_5 may reject explicit uz.
ELEVENLABS_LANGUAGE_CODE=auto

# Kokoro local TTS. Required when COMPANION_TTS_PROVIDER=kokoro.
KOKORO_MODEL_PATH=
KOKORO_VOICE_NAME=

# Optional voice analysis providers.
HUME_API_KEY=
HUME_EVI_CONFIG_ID=
HUME_EVI_WS_URL=wss://api.hume.ai/v0/evi/chat
HUME_BASE_URL=https://api.hume.ai
# Optional dev fixture: path to a saved Hume-style JSON response for local mapping tests.
HUME_FIXTURE_PATH=
ASSEMBLYAI_API_KEY=
DEEPGRAM_API_KEY=
